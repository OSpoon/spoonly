---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const bookmarkCollection = await getCollection('bookmarks');
const groups = bookmarkCollection.map(b => b.data);
---

<Layout title="Bookmarks">
	<header class="page-header">
		<h1>The Library</h1>
		<p>A curated collection of digital artifacts, tools, and inspirations.</p>
	</header>

	<div class="bookmarks-container">
		{groups.map((group) => (
			<section class="bookmark-group">
				<h2>{group.category}</h2>
				<ul class="bookmark-list">
					{group.items.map((item) => (
						<li class="bookmark-item">
							<a href={item.url} target="_blank" rel="noopener noreferrer">
								<span class="name">{item.name}</span>
								<span class="url">{new URL(item.url).hostname}</span>
							</a>
							{item.desc && <p class="desc">{item.desc}</p>}
						</li>
					))}
				</ul>
			</section>
		))}
	</div>
</Layout>

<style>
	.page-header {
		padding: 2rem 0;
		border-bottom: 1px solid var(--border-color);
		margin-bottom: 3rem;
	}

	.page-header h1 {
		margin-top: 0;
		font-size: 1.85rem;
	}

	.page-header p {
		color: var(--text-muted);
		font-size: 0.9rem;
	}

	.bookmarks-container {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.bookmark-group h2 {
		font-size: 1.15rem;
		border-bottom: 1px solid var(--border-color);
		padding-bottom: 0.5rem;
		margin-bottom: 1.5rem;
		font-family: 'Fraunces', serif;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--text-muted);
	}

	.bookmark-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
		gap: 2rem;
	}

	.bookmark-item {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.bookmark-item a {
		display: flex;
		align-items: baseline;
		gap: 0.6rem;
		color: var(--text-color);
		font-weight: 600;
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: 0.95rem;
	}

	.bookmark-item a:hover .name {
		text-decoration: underline;
	}

	.bookmark-item .url {
		font-size: 0.7rem;
		font-family: 'JetBrains Mono', monospace;
		color: var(--text-muted);
		font-weight: 400;
	}

	.bookmark-item .desc {
		margin: 0;
		font-size: 0.8rem;
		color: var(--text-muted);
		line-height: 1.5;
	}

	@media (max-width: 640px) {
		.bookmark-list {
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}
	}
</style>
