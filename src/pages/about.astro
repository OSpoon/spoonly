---
import Layout from '../layouts/Layout.astro';
import aboutData from '../data/about.json';
import { marked } from 'marked'; // Need to install this or use simple regex for basic bold/italic

const { intro, experience, skills, connect } = aboutData;
---

<Layout title="About">
	<header class="page-header">
		<h1>{intro.title}</h1>
		<p>{intro.tagline}</p>
	</header>

	<section class="about-intro">
		<div class="bio-text">
			{intro.bio.map(paragraph => (
				<p set:html={paragraph.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\*(.*?)\*/g, '<em>$1</em>').replace(/_(.*?)_/g, '<em>$1</em>')} />
			))}
		</div>
	</section>

	<section class="section">
		<h2 class="section-title">Experience</h2>
		<div class="timeline">
			{experience.map(item => (
				<div class="timeline-item">
					<div class="time">{item.period}</div>
					<div class="content">
						<h3>{item.company}</h3>
						<p>{item.description}</p>
					</div>
				</div>
			))}
		</div>
	</section>

	<section class="section">
		<h2 class="section-title">Capabilities</h2>
		<div class="skills-grid">
			{skills.map(group => (
				<div class="skill-group">
					<span class="group-name">{group.category}</span>
					<div class="tags">
						{group.items.map(skill => (
							<span class="tag">{skill}</span>
						))}
					</div>
				</div>
			))}
		</div>
	</section>

	<section class="section">
		<h2 class="section-title">Connect</h2>
		<div class="connect-links">
			{connect.map((link, index) => (
				<>
					<a href={link.url} target="_blank">{link.name}</a>
					{index < connect.length - 1 && <span class="separator">/</span>}
				</>
			))}
		</div>
	</section>
</Layout>

<style>
	.page-header {
		padding: 2rem 0;
		border-bottom: 1px solid var(--border-color);
		margin-bottom: 3rem;
	}

	.page-header h1 {
		margin-top: 0;
		font-size: 1.85rem;
	}

	.page-header p {
		color: var(--text-muted);
		font-size: 0.95rem;
	}

	.about-intro {
		margin-bottom: 4rem;
		max-width: 660px;
	}

	.bio-text p {
		font-size: 1.05rem;
		line-height: 1.8;
		margin-bottom: 1.5rem;
		color: var(--text-color);
	}

	.section {
		margin-bottom: 4rem;
	}

	.section-title {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--text-muted);
		margin-bottom: 2rem;
		border-bottom: none;
	}

	.timeline {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.timeline-item {
		display: flex;
		gap: 3rem;
	}

	.timeline-item .time {
		min-width: 100px;
		font-family: 'Fraunces', serif;
		font-size: 0.95rem;
		color: var(--text-muted);
		padding-top: 0.2rem;
	}

	.timeline-item h3 {
		margin: 0 0 0.5rem 0;
		font-size: 1.25rem;
	}

	.timeline-item p {
		margin: 0;
		color: var(--text-muted);
		max-width: 480px;
		font-size: 0.9rem;
	}

	.skills-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 2.5rem;
	}

	.skill-group {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.group-name {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.75rem;
		color: var(--text-muted);
		text-transform: uppercase;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.tag {
		font-size: 0.9rem;
		color: var(--text-color);
		font-weight: 500;
	}

	.connect-links {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		font-family: 'Fraunces', serif;
		font-size: 1.25rem;
	}

	.separator {
		color: var(--border-color);
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-weight: 300;
	}

	@media (max-width: 640px) {
		.timeline-item {
			flex-direction: column;
			gap: 0.4rem;
		}
		
		.timeline-item .time {
			min-width: auto;
		}

		.connect-links {
			font-size: 1.1rem;
			gap: 0.75rem;
		}
	}
</style>
