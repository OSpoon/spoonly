---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projectsCollection = await getCollection('projects');
const allProjects = projectsCollection
	.map(p => p.data)
	.sort((a, b) => (a._order || 0) - (b._order || 0));
---

<Layout title="Projects">
	<header class="page-header">
		<h1>My Open Source Projects</h1>
		<p>A collection of tools, frameworks, and libraries I've built.</p>
	</header>

	<div class="projects-grid">
		{allProjects.map(project => (
			<div class="project-card">
				<div class="project-header">
					<svg height="16" viewBox="0 0 16 16" width="16" class="repo-icon"><path d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 110-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5v-9zm10.5-1V9h-8c-.356 0-.694.074-1 .208V2.5a1 1 0 011-1h8zM5 12.25v3.25a.25.25 0 00.4.2l1.45-1.087a.25.25 0 01.3 0L8.6 15.7a.25.25 0 00.4-.2v-3.25a.25.25 0 00-.25-.25h-3.5a.25.25 0 00-.25.25z" fill="currentColor"></path></svg>
					<h3><a href={project.url} target="_blank">{project.name}</a></h3>
				</div>
				<p>{project.description}</p>
				<div class="project-footer">
					<span class="language">
						<span class={`dot ${project.language.toLowerCase()}`}></span>
						{project.language}
					</span>
					{project.stars !== undefined && (
						<span class="stars">
							<svg height="16" viewBox="0 0 16 16" width="16" class="star-icon"><path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.751.751 0 01-1.088.791L8 12.347l-3.766 1.98a.751.751 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25zm0 2.445L6.615 5.5a.75.75 0 01-.564.41l-3.097.45 2.24 2.184a.75.75 0 01.216.664l-.528 3.084 2.769-1.456a.75.75 0 01.698 0l2.77 1.456-.53-3.084a.75.75 0 01.216-.664l2.24-2.183-3.096-.45a.75.75 0 01-.564-.41L8 2.694v.001z" fill="currentColor"></path></svg>
							{project.stars}
						</span>
					)}
				</div>
			</div>
		))}
	</div>
</Layout>

<style>
	.page-header {
		padding: 2rem 0;
		border-bottom: 1px solid var(--border-color);
		margin-bottom: 2rem;
	}

	.page-header h1 {
		margin-top: 0;
		font-size: 1.85rem;
	}

	.page-header p {
		color: var(--text-muted);
		font-size: 0.9rem;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	.project-card {
		background-color: transparent !important;
		border: none;
		border-bottom: 1px solid var(--border-color);
		border-radius: 0;
		padding: 1.5rem 0;
		transition: transform 0.3s ease, border-bottom-color 0.3s ease;
	}

	.project-card:last-child {
		border-bottom: none;
	}

	.project-card:hover {
		transform: translateX(8px);
		border-bottom-color: var(--text-color);
	}

	.project-header {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 0.5rem;
	}

	.project-header h3 {
		margin: 0;
		font-size: 1.35rem;
		font-family: 'Fraunces', serif;
	}

	.repo-icon {
		color: var(--text-muted);
		width: 14px;
		height: 14px;
	}

	.project-card p {
		font-size: 0.9rem;
		color: var(--text-muted);
		margin: 0 0 1rem 0;
		line-height: 1.6;
		max-width: 600px;
	}

	.project-footer {
		display: flex;
		gap: 1.25rem;
		font-size: 0.75rem;
		color: var(--text-muted);
		font-family: 'JetBrains Mono', monospace;
	}

	.language, .stars {
		display: flex;
		align-items: center;
		gap: 0.35rem;
	}

	.dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
	}

	.dot.vue { background-color: #41b883; }
	.dot.typescript { background-color: #3178c6; }
	.dot.javascript { background-color: #f1e05a; }
	.dot.node\.js { background-color: #339933; }
	.dot.go { background-color: #00add8; }
	.dot.css { background-color: #563d7c; }
	.dot.html { background-color: #e34c26; }

	.star-icon {
		color: var(--text-muted);
		width: 14px;
		height: 14px;
	}
</style>
